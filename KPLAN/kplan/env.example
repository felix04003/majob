# ─── Supabase (REQUIRED) ────────────────────────────────────────────────────
# Get these from: https://supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# ─── Email — Resend (RECOMMENDED) ──────────────────────────────────────────
# Get your API key from: https://resend.com → API Keys
# Without this, invitation emails won't be sent (logged to console instead).
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx
# Sender address (must be verified in Resend, or use their default onboarding domain)
KPLAN_FROM_EMAIL=Kplan <noreply@kplan.app>

# ─── App Config (OPTIONAL) ──────────────────────────────────────────────────
# Email of the single admin planner (restricts /planner access)
KPLAN_ADMIN_EMAIL=you@example.com

# ─── Monitoring — Sentry (OPTIONAL) ─────────────────────────────────────────
# Get your DSN from: https://sentry.io → Project Settings → Client Keys (DSN)
# Without this, Sentry is disabled (no errors tracked).
NEXT_PUBLIC_SENTRY_DSN=https://xxxxxxx@oXXXXXX.ingest.sentry.io/XXXXXXX
# Auth token for source map uploads (build-time only)
SENTRY_AUTH_TOKEN=sntrys_xxxxxxxxxxxxxxxxxxxxx
SENTRY_ORG=your-org
SENTRY_PROJECT=kplan
